# Copier ce fichier en .env et remplir les valeurs

# Port du serveur backend
PORT=3001

# Secret JWT — changer par une valeur longue et aléatoire en production
JWT_SECRET=changez_ce_secret_en_production_utilisez_une_chaine_aleatoire_longue

# Origine autorisée pour CORS (votre domaine en production)
# En dev: http://localhost:5173
# En prod: https://votre-domaine.com
CORS_ORIGIN=http://localhost:5173

# Environnement
NODE_ENV=development
